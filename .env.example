# Blaxx Pontos · backend · variáveis de ambiente
# Copie para .env e ajuste os valores. NUNCA commite .env.
#
# Filosofia: tudo que precisa de credencial é OPCIONAL e fica DESLIGADO por
# padrão (homologação). O app sobe em modo mock/console sem nenhuma chave. Para
# ativar um provedor real, defina as variáveis da seção correspondente — o
# código já tem o hook; nenhuma mudança de fonte é necessária.

# --------------------------------------------------------------
# Database
# --------------------------------------------------------------
# Dev local: SQLite com arquivo
DATABASE_URL=sqlite:///instance/blaxx.db

# Prod: Postgres (Neon/Supabase/Render)
# DATABASE_URL=postgresql+psycopg://user:senha@host/banco?sslmode=require

# --------------------------------------------------------------
# Segurança · Onda 1
# --------------------------------------------------------------
# Gere com: python3 -c "import secrets; print(secrets.token_hex(32))"
# Em produção o boot ABORTA se estes ainda forem o placeholder 'dev-only...'.
SECRET_KEY=dev-only-change-me-32-chars-minimum
JWT_SECRET_KEY=dev-only-change-me-32-chars-minimum

# Ambiente: development | production. Em production, secrets default e
# MAILER=console fazem o boot abortar (fail-fast). Default: production.
# FLASK_ENV=development

# --------------------------------------------------------------
# CORS — domínios autorizados a chamar a API
# --------------------------------------------------------------
CORS_ORIGINS=https://blaxxpontos.com.br,https://www.blaxxpontos.com.br,http://localhost:5173,http://127.0.0.1:5173

# URL do frontend para construir links em emails (reset de senha)
FRONTEND_URL=https://blaxxpontos.com.br

# --------------------------------------------------------------
# PIX provider  ·  mock (default) | mercadopago
# --------------------------------------------------------------
# Sem MP_ACCESS_TOKEN o provider cai automaticamente no mock (homologação).
PIX_PROVIDER=mock
# MP_ACCESS_TOKEN=APP_USR-xxxxxxxx        # Sandbox: TEST- · Prod: APP_USR-
# MP_WEBHOOK_SECRET=xxxxxxxx              # segredo do webhook configurado no painel MP
# MP_NOTIFICATION_URL=https://blaxx-pontos-exe.onrender.com/pix/webhook
# MP_WEBHOOK_MAX_CLOCK_SKEW=300           # anti-replay (segundos)

# Para webhook PIX genérico (não-MP):
# PIX_WEBHOOK_SECRET=gerado-com-openssl-rand-hex-24
# PIX_WEBHOOK_ALLOWED_IPS=189.123.45.67,189.123.45.68

# --------------------------------------------------------------
# E-mail (mailer)  ·  console (default dev) | resend | noop
# --------------------------------------------------------------
# console = grava em /tmp + loga corpo (NÃO use em prod: vaza códigos/tokens).
# noop    = ignora (testes).
# resend  = Resend.com API (free 3k/mês, sem dependência — usa urllib).
# OBS: em produção, MAILER=console faz o boot abortar — use resend ou noop.
MAILER=console
# MAILER=resend
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=BlaXx <no-reply@blaxxpontos.com.br>   # domínio precisa estar verificado no Resend

# --------------------------------------------------------------
# SMS / OTP (2FA por telefone)  ·  console (default) | twilio
# --------------------------------------------------------------
# console = loga o código no stdout (dev/CI). twilio = API REST (urllib).
SMS_BACKEND=console
# SMS_BACKEND=twilio
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxx
# TWILIO_FROM_PHONE=+15551234567
# PHONE_OTP_TTL=600            # validade do código de verificação (s)
# MFA_CHALLENGE_TTL=300        # validade do desafio de login 2FA (s)
# PHONE_OTP_COOLDOWN=60        # intervalo mínimo entre reenvios (s)

# --------------------------------------------------------------
# Monitoramento de erros (Sentry)  ·  desligado por padrão
# --------------------------------------------------------------
# Ativa SÓ se SENTRY_DSN estiver setado. before_send remove PII (email, CPF,
# telefone, tokens) antes de subir o evento. sentry-sdk já está no requirements.
# SENTRY_DSN=https://xxxxxxxx@oYYYY.ingest.sentry.io/ZZZZ
# SENTRY_TRACES_RATE=0.05      # amostragem de performance (0.0–1.0)
# RELEASE_VERSION=0.1.0        # tag de release reportada ao Sentry

# --------------------------------------------------------------
# Apple Wallet (PassKit)  ·  cartão .pkpass — desligado por padrão
# --------------------------------------------------------------
# Sem os certificados, /card/pass responde 503 e os apps mostram "em breve".
# Requer conta Apple Developer + Pass Type ID. Suba os .p12/.pem como secrets.
# APPLE_PASS_TYPE_ID=pass.com.blaxx.cartao
# APPLE_TEAM_ID=ABCDE12345
# APPLE_PASS_CERT_PATH=/etc/secrets/pass.p12
# APPLE_PASS_CERT_PASSWORD=xxxxxxxx
# APPLE_WWDR_CERT_PATH=/etc/secrets/wwdr.pem
# APPLE_PASS_ORG_NAME=Blaxx Pontos

# --------------------------------------------------------------
# Google OAuth  ·  opcional (defaults públicos já embutidos)
# --------------------------------------------------------------
# Os Client IDs NÃO são segredos (já vão no bundle do site/app). Só sobrescreva
# se trocar o projeto no Google Cloud Console.
# GOOGLE_WEB_CLIENT_ID=xxxx.apps.googleusercontent.com
# GOOGLE_IOS_CLIENT_ID=xxxx.apps.googleusercontent.com

# --------------------------------------------------------------
# Rate limiter
# --------------------------------------------------------------
# Dev: memory · Prod: redis:// (com >1 worker, memory:// dobra o limite efetivo)
RATELIMIT_STORAGE_URI=memory://
# RATELIMIT_STORAGE_URI=redis://default:senha@host:6379

# --------------------------------------------------------------
# Server
# --------------------------------------------------------------
BLAXX_BACKEND_HOST=127.0.0.1
BLAXX_BACKEND_PORT=5050
